---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RecordingCard from "@/components/RecordingCard.astro";
import Icon from "@/components/Icon.astro";
import { getEnv } from "@/lib/runtime";
import { listRecordings } from "@/lib/content";
import { SOCIALS, BRAND } from "@/lib/site";
import { imageSrc, ytPlaylistId, ytPlaylistUrl } from "@/lib/ui";

const env = getEnv(Astro.locals);
const recs = await listRecordings(env);

// hero coverflow — cards rotate through recordings, 3 visible (front + 2 behind)
const hours = (m: number) => Math.max(1, Math.round(m / 60));
const cards = recs
  .map((r) => {
    const ytId = r.playlist_id || ytPlaylistId(r.youtube_url);
    return {
      img: imageSrc(r.cover_image) || (ytId ? `/yt/${ytId}` : ""),
      href: r.youtube_url || (ytId ? ytPlaylistUrl(ytId) : "#"),
      title: r.title,
      category: r.category,
      videos: r.video_count,
      hours: r.duration_minutes ? hours(r.duration_minutes) : 0,
    };
  })
  .filter((c) => c.img)
  .slice(0, 10);

// hero metrics — standard inline layout (count · hours · price)
const totalMinutes = recs.reduce((a, r) => a + (r.duration_minutes || 0), 0);
const totalHours = Math.round(totalMinutes / 60);
const metrics = [
  { value: `${recs.length}+`, label: "Kayıt" },
  { value: `${totalHours}+`, label: "Saat içerik" },
  { value: "0₺", label: "Tamamen ücretsiz" },
];

// odometer roll — same animation as the homepage ImpactStrip
const CYCLES = 4;
const odoTokens = (v: string) =>
  [...v].map((ch) => (/\d/.test(ch) ? { digit: Number(ch) } : { sep: ch }));
const odoTo = (d: number) => (CYCLES - 1) * 10 + d;

const groups = [
  { key: "event", label: "Etkinlik kayıtları" },
  { key: "bootcamp", label: "Bootcamp serisi" },
  { key: "talk", label: "Konuşmalar" },
  { key: "series", label: "Seriler" },
];
const known = new Set(groups.map((g) => g.key));
const sections = groups
  .map((g) => ({ ...g, items: recs.filter((r) => r.category === g.key) }))
  .filter((s) => s.items.length > 0);
const other = recs.filter((r) => !known.has(r.category));
if (other.length) sections.push({ key: "other", label: "Daha fazla", items: other });
---

<BaseLayout
  title="Etkinlik Kayıtları & Konuşmalar"
  description="Developer MultiGroup'tan konuşmaları, konferansları ve bootcamp serilerini YouTube'da tekrar izle."
  canonicalPath="/recordings"
  breadcrumbs={[{ name: "Kayıtlar", item: `${BRAND.url}/recordings` }]}
>
  <section class="container-x pt-14 pb-8">
    <div class="grid lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] gap-10 lg:gap-12 items-center">
      <div>
        <p class="text-sm text-ink-faint uppercase tracking-[0.18em] mb-4">Kayıtlar · YouTube</p>
        <h1 class="text-4xl md:text-5xl font-semibold leading-[1.05]">
          Kaçırdığını <span class="text-grad">tekrar izle.</span>
        </h1>
        <p class="text-ink-dim text-lg mt-5 max-w-md leading-relaxed">
          Düzenlediğimiz neredeyse her şeyi kaydediyoruz — konuşmalar, konferanslar ve
          bootcamp serileri.
        </p>
        <dl class="flex items-stretch gap-5 sm:gap-7 mt-8" data-odo-root>
          {metrics.map((m, i) => (
            <>
              {i > 0 && <div class="cf-metric w-px self-stretch bg-line" style={`--d:${i * 70}ms`} aria-hidden="true" />}
              <div class="cf-metric" style={`--d:${i * 70}ms`}>
                <dd class="impact-kpi-num font-display font-semibold tabular-nums leading-none">
                  <span class="odo-wrap">
                    {odoTokens(m.value).map((t) =>
                      t.sep !== undefined ? (
                        <span class="odo-sep">{t.sep}</span>
                      ) : (
                        <span class="odo">
                          <span class="odo-col" data-to={odoTo(t.digit ?? 0)} style={`transform:translateY(-${odoTo(t.digit ?? 0)}em)`}>
                            {Array.from({ length: CYCLES * 10 }, (_, k) => (
                              <span class="odo-d">{k % 10}</span>
                            ))}
                          </span>
                        </span>
                      ),
                    )}
                  </span>
                </dd>
                <dt class="text-ink-faint text-xs sm:text-sm mt-2">{m.label}</dt>
              </div>
            </>
          ))}
        </dl>
        <a
          href={SOCIALS.multigroup.youtube}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary mt-8"
          data-track="cta_click"
          data-track-props={JSON.stringify({ cta_id: "recordings_youtube", page: "recordings", href: SOCIALS.multigroup.youtube })}
        >
          <Icon name="youtube" size={18} /> Kanalı ziyaret et
        </a>
      </div>

      {
        cards.length >= 3 && (
          <div class="cf-wrap">
            <div id="cf-stage" class="cf-stage" role="group" aria-label="Kayıt önizlemeleri">
              {cards.map((c, i) => (
                <a
                  href={c.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="cf-card"
                  data-i={i}
                  aria-label={c.title}
                  data-track="recording_play"
                  data-track-props={JSON.stringify({ recording_title: c.title, recording_category: c.category, video_count: c.videos, page: "recordings_coverflow" })}
                >
                  <div class="cf-inner card">
                    <img src={c.img} alt="" loading="lazy" decoding="async" class="cf-img" />
                    <div class="cf-shade" />
                    <div class="cf-badges">
                      <span class="cf-badge">
                        <Icon name="play" size={11} /> {c.videos} video
                      </span>
                      {c.hours > 0 && <span class="cf-badge">{c.hours} saat</span>}
                    </div>
                    <h3 class="cf-title">{c.title}</h3>
                    <span class="cf-play">
                      <Icon name="play" size={18} />
                    </span>
                  </div>
                </a>
              ))}
            </div>
            <div id="cf-dots" class="cf-dots">
              {cards.map((_, i) => (
                <button type="button" class="cf-dot" data-i={i} aria-label={`Kayıt ${i + 1}`} />
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>

  {
    recs.length === 0 ? (
      <section class="container-x py-10">
        <div class="card p-12 text-center text-ink-dim">
          <Icon name="play" size={28} class="mx-auto mb-3 opacity-50" /> Oynatma listeleri hazırlanıyor — birazdan burada.
        </div>
      </section>
    ) : (
      sections.map((s) => (
        <section class="container-x py-6">
          <h2 class="font-display text-xl font-semibold mb-5">{s.label}</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {s.items.map((r) => <RecordingCard rec={r} page="recordings" />)}
          </div>
        </section>
      ))
    )
  }

  <style>
    .cf-wrap {
      --cf-ease: cubic-bezier(0.22, 0.61, 0.36, 1);
    }
    /* metric reveal (fade-up) — mirrors the homepage ImpactStrip */
    .cf-metric {
      opacity: 0;
      transform: translateY(16px);
      transition:
        opacity 0.5s var(--ease-out-soft),
        transform 0.5s var(--ease-out-soft);
      transition-delay: var(--d, 0ms);
    }
    .cf-metric.is-in {
      opacity: 1;
      transform: none;
    }
    .impact-kpi-num {
      font-size: clamp(1.75rem, 5vw, 2.75rem);
      letter-spacing: -0.02em;
    }
    /* odometer digit roll */
    .odo-wrap {
      display: inline-flex;
      align-items: flex-end;
    }
    .odo,
    .odo-sep {
      display: inline-block;
      height: 1em;
      line-height: 1;
    }
    .odo {
      overflow: hidden;
    }
    .odo-col {
      display: flex;
      flex-direction: column;
      transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .odo-d {
      display: block;
      height: 1em;
      line-height: 1;
    }
    @media (prefers-reduced-motion: reduce) {
      .cf-metric {
        opacity: 1;
        transform: none;
        transition: none;
      }
      .odo-col {
        transition: none;
      }
    }
    .cf-stage {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 10;
      perspective: 1700px;
      /* NB: no transform-style:preserve-3d — it makes rotated side cards' near
         edges win the depth test over the flat active card, leaking through as
         translucent panels. perspective alone gives the tilt; z-index stays
         authoritative. */
    }
    .cf-card {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 62%;
      aspect-ratio: 16 / 9;
      transform: translate(-50%, -50%);
      transform-origin: center center;
      transition:
        transform 0.7s var(--cf-ease),
        opacity 0.7s var(--cf-ease);
      will-change: transform, opacity;
    }
    .cf-inner {
      position: absolute;
      inset: 0;
      overflow: hidden;
      border-radius: 1rem;
      box-shadow: 0 30px 60px -28px rgba(0, 0, 0, 0.9);
    }
    .cf-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .cf-shade {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.82) 4%, rgba(0, 0, 0, 0.15) 42%, transparent 70%);
    }
    .cf-badges {
      position: absolute;
      top: 0.7rem;
      left: 0.7rem;
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
    }
    .cf-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.25rem 0.55rem;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 500;
      font-variant-numeric: tabular-nums;
      color: var(--color-ink-text);
      background: rgba(0, 0, 0, 0.62);
      border: 1px solid var(--color-line-strong);
      backdrop-filter: blur(6px);
    }
    .cf-title {
      position: absolute;
      left: 0.85rem;
      right: 0.85rem;
      bottom: 0.8rem;
      font-family: var(--font-display, inherit);
      font-weight: 600;
      font-size: 1.02rem;
      line-height: 1.25;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .cf-play {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) scale(0.9);
      display: grid;
      place-items: center;
      width: 3.1rem;
      height: 3.1rem;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.5);
      border: 1px solid var(--color-line-strong);
      color: #fff;
      opacity: 0;
      transition:
        opacity 0.35s var(--cf-ease),
        transform 0.35s var(--cf-ease);
    }
    /* positions assigned by JS via data-pos */
    .cf-card[data-pos="0"] {
      transform: translate(-50%, -50%) scale(1) rotateY(0);
      z-index: 30;
      opacity: 1;
    }
    .cf-card[data-pos="0"] .cf-play {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
    .cf-card[data-pos="0"]:hover .cf-play {
      transform: translate(-50%, -50%) scale(1.1);
    }
    .cf-card[data-pos="l"] {
      transform: translate(-93%, -50%) scale(0.8) rotateY(34deg);
      z-index: 20;
      opacity: 0.48;
    }
    .cf-card[data-pos="r"] {
      transform: translate(-7%, -50%) scale(0.8) rotateY(-34deg);
      z-index: 20;
      opacity: 0.48;
    }
    .cf-card[data-pos="fl"] {
      transform: translate(-110%, -50%) scale(0.6) rotateY(42deg);
      z-index: 10;
      opacity: 0;
      pointer-events: none;
    }
    .cf-card[data-pos="fr"] {
      transform: translate(10%, -50%) scale(0.6) rotateY(-42deg);
      z-index: 10;
      opacity: 0;
      pointer-events: none;
    }
    .cf-card[data-pos="l"]:hover,
    .cf-card[data-pos="r"]:hover {
      opacity: 0.72;
      cursor: pointer;
    }
    .cf-dots {
      display: flex;
      justify-content: center;
      gap: 0.45rem;
      margin-top: 1.5rem;
    }
    .cf-dot {
      width: 0.45rem;
      height: 0.45rem;
      border-radius: 999px;
      background: var(--color-line-strong);
      transition:
        width 0.4s var(--cf-ease),
        background 0.4s var(--cf-ease);
    }
    .cf-dot.is-active {
      width: 1.4rem;
      background: var(--color-ink-text);
    }
    @media (prefers-reduced-motion: reduce) {
      .cf-card {
        transition: opacity 0.2s linear;
      }
    }
  </style>

  <noscript>
    <style>
      .cf-metric {
        opacity: 1 !important;
        transform: none !important;
      }
    </style>
  </noscript>

  <script is:inline>
    (() => {
      const init = () => {
        document.querySelectorAll("[data-odo-root]").forEach((root) => {
          if (root.dataset.odoBound) return;
          root.dataset.odoBound = "1";
          const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
          const run = () => {
            root.querySelectorAll(".cf-metric").forEach((el) => el.classList.add("is-in"));
            if (reduce) return;
            root.querySelectorAll(".odo-col").forEach((col, di) => {
              const to = col.dataset.to;
              // reset to 0 then roll down to the (already-rendered) target
              col.style.transition = "none";
              col.style.transform = "translateY(0)";
              void col.offsetHeight; // reflow so the reset applies instantly
              col.style.transition = "";
              col.style.transitionDelay = di * 70 + "ms";
              col.style.transform = "translateY(-" + to + "em)";
            });
          };
          if (!("IntersectionObserver" in window)) {
            run();
            return;
          }
          const io = new IntersectionObserver(
            (obs) => {
              obs.forEach((e) => {
                if (e.isIntersecting) {
                  run();
                  io.disconnect();
                }
              });
            },
            { threshold: 0.3 },
          );
          io.observe(root);
        });
      };
      if (!window.__dmgOdometer) {
        window.__dmgOdometer = true;
        document.addEventListener("astro:page-load", init);
      }
      init();
    })();
  </script>

  <script is:inline>
    (() => {
      function init() {
        const stage = document.getElementById("cf-stage");
        if (!stage || stage.dataset.bound) return;
        stage.dataset.bound = "1";
        const cards = [...stage.querySelectorAll(".cf-card")];
        const dots = [...document.querySelectorAll("#cf-dots .cf-dot")];
        const N = cards.length;
        if (N < 2) return;
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        let active = 0;
        let timer = null;

        function layout() {
          cards.forEach((card, i) => {
            let rel = i - active;
            if (rel > N / 2) rel -= N;
            if (rel < -N / 2) rel += N;
            card.dataset.pos = rel === 0 ? "0" : rel === -1 ? "l" : rel === 1 ? "r" : rel < 0 ? "fl" : "fr";
          });
          dots.forEach((d, i) => d.classList.toggle("is-active", i === active));
        }
        function go(i) {
          active = ((i % N) + N) % N;
          layout();
        }
        function stop() {
          if (timer) clearInterval(timer);
          timer = null;
        }
        function start() {
          if (reduce) return;
          stop();
          timer = setInterval(() => go(active + 1), 3800);
        }

        cards.forEach((card, i) => {
          card.addEventListener("click", (e) => {
            if (i !== active) {
              e.preventDefault();
              go(i);
              start();
            }
          });
        });
        dots.forEach((d, i) =>
          d.addEventListener("click", () => {
            go(i);
            start();
          }),
        );
        stage.addEventListener("mouseenter", stop);
        stage.addEventListener("mouseleave", start);

        layout();
        start();
      }
      if (!window.__dmgCoverflow) {
        window.__dmgCoverflow = true;
        document.addEventListener("astro:page-load", init);
      }
      init();
    })();
  </script>
</BaseLayout>
