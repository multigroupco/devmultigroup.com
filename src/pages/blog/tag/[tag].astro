---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import Icon from "@/components/Icon.astro";
import { getEnv } from "@/lib/runtime";
import { listPosts } from "@/lib/content";

const env = getEnv(Astro.locals);
const { tag = "" } = Astro.params;
const decoded = decodeURIComponent(tag);
const posts = await listPosts(env, { tag: decoded, limit: 40 });
---

<BaseLayout
  title={`#${decoded}`}
  description={`Developer MultiGroup blog'unda “${decoded}” etiketli yazılar.`}
  canonicalPath={`/blog/tag/${tag}`}
>
  <section class="container-x pt-14 pb-8">
    <a href="/blog" class="inline-flex items-center gap-1.5 text-sm text-ink-dim hover:text-ink-text mb-6" data-track="nav_click" data-track-props={JSON.stringify({ location: "blog_tag", nav_label: "Tüm yazılar", href: "/blog" })}>
      <Icon name="arrow-right" size={15} class="rotate-180" /> Tüm yazılar
    </a>
    <h1 class="text-4xl md:text-5xl font-semibold">#{decoded}</h1>
    <p class="text-ink-dim mt-3">{posts.length} {posts.length === 1 ? "yazı" : "yazı"}</p>
  </section>

  <section class="container-x py-4">
    {
      posts.length > 0 ? (
        <div class="grid md:grid-cols-3 gap-4">
          {posts.map((p) => <PostCard post={p} page="blog_tag" />)}
        </div>
      ) : (
        <div class="card p-12 text-center text-ink-dim">Henüz “{decoded}” etiketli bir şey yok.</div>
      )
    }
  </section>
</BaseLayout>
