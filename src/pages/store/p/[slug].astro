---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";
import AsciiReveal from "@/components/store/AsciiReveal.astro";
import { getEnv } from "@/lib/runtime";
import { getProduct, getVariants } from "@/lib/store/catalog";
import { parseImages, storeImageSrc } from "@/lib/store/db";
import { money } from "@/lib/store/format";
import { STORE } from "@/lib/store/config";

const env = getEnv(Astro.locals);
const { slug = "" } = Astro.params;
const product = await getProduct(env, slug);
if (!product || Number(product.is_active) !== 1) return Astro.redirect("/store");

const variants = await getVariants(env, product.id);

const remaining = Number(product.remaining ?? 0);
const soldOut = remaining <= 0;

const img = storeImageSrc(parseImages(product.images)[0]);
const hasVariants = variants.length > 0;
const firstAvailable = variants.findIndex((v) => v.stock_quantity > 0);
const variantView = variants.map((v, i) => ({
  id: v.id,
  label: v.label,
  stock: v.stock_quantity,
  out: v.stock_quantity <= 0,
  checked: i === firstAvailable,
}));

const CAT: Record<string, string> = { giyim: "Giyim", yasam: "Yaşam", koleksiyon: "Koleksiyon" };
const sheet = [
  { k: "Malzeme", v: product.material },
  { k: "Kalıp", v: product.fit_note },
  { k: "Beden tablosu", v: product.size_chart },
].filter((r) => r.v);

const err = Astro.url.searchParams.get("err");
const inputCls = "w-full bg-ink-900 border border-line rounded-xl px-3.5 py-2.5 text-sm text-ink-text placeholder:text-ink-faint focus:border-violet outline-none transition-colors";

// Analytics context for the product-detail funnel (view → variant → reserve).
const productView = {
  product_id: product.id,
  product_name: product.name,
  price_minor: product.base_price_minor,
  category: product.category,
  stock_remaining: remaining,
  sold_out: soldOut,
};
---

<BaseLayout
  title={product.name}
  description={product.tagline || product.description || product.name}
  canonicalPath={`/store/p/${product.slug}`}
  breadcrumbs={[
    { name: "Mağaza", item: "https://devmultigroup.com/store" },
    { name: product.name, item: `https://devmultigroup.com/store/p/${product.slug}` },
  ]}
>
  <section class="container-x pt-14 md:pt-20 pb-20">
    <a href="/store" class="inline-flex items-center gap-1.5 text-sm text-ink-dim hover:text-ink-text mb-6">
      <Icon name="arrow-right" size={15} class="rotate-180" /> Mağaza
    </a>

    <div class="grid md:grid-cols-2 gap-8 lg:gap-12 items-start">
      <!-- gallery -->
      <div class="card relative aspect-square overflow-hidden bg-ink-950 md:sticky md:top-24">
        {
          img ? (
            <img src={img} alt={product.name} decoding="async" data-ascii class="absolute inset-0 w-full h-full object-cover" />
          ) : (
            <div class="absolute inset-0 grid place-items-center p-10 text-center">
              <span class="font-mono text-sm text-ink-faint break-words leading-relaxed">{product.name}</span>
            </div>
          )
        }
        <span class="absolute top-4 left-4 chip z-[3]">{CAT[product.category] ?? product.category}</span>
        {soldOut && <span class="absolute top-4 right-4 chip border-line-strong text-ink-text z-[3]">TÜKENDİ</span>}
      </div>

      <!-- info + reserve -->
      <div>
        <h1 class="text-3xl md:text-4xl font-semibold leading-tight">{product.name}</h1>
        {product.tagline && <p class="font-mono text-sm text-ink-faint mt-2">{product.tagline}</p>}

        <div class="mt-5 flex items-end gap-3">
          <span class="font-display text-3xl text-grad tabular-nums">{money(product.base_price_minor)}</span>
          <span class="text-xs text-ink-faint font-mono mb-1">KDV dahil</span>
        </div>

        {product.description && <p class="text-ink-dim mt-5 leading-relaxed">{product.description}</p>}

        {
          sheet.length > 0 && (
            <dl class="mt-6 card divide-y divide-line-soft">
              {sheet.map((r) => (
                <div class="flex gap-4 px-4 py-3 text-sm">
                  <dt class="w-32 shrink-0 font-mono text-xs uppercase tracking-wide text-ink-faint pt-0.5">{r.k}</dt>
                  <dd class="text-ink-dim">{r.v}</dd>
                </div>
              ))}
            </dl>
          )
        }

        <!-- reserve -->
        <div class="card p-5 mt-6">
          {err && <p class="mb-4 text-sm text-coral">{err}</p>}

          {
            soldOut ? (
              <p class="text-ink-dim text-sm inline-flex items-center gap-2">
                <Icon name="close" size={16} /> Bu ürün şu an tükendi.
              </p>
            ) : (
              <form method="POST" action="/api/store/reserve" class="space-y-4">
                <input type="hidden" name="productId" value={product.id} />
                <input type="hidden" name="slug" value={product.slug} />

                {hasVariants && (
                  <fieldset>
                    <legend class="text-sm text-ink-dim mb-2">Beden / varyant</legend>
                    <div class="flex flex-wrap gap-2">
                      {variantView.map((v) => (
                        <label class={v.out ? "cursor-not-allowed" : "cursor-pointer"}>
                          <input type="radio" name="variantId" value={v.id} class="peer sr-only" required disabled={v.out} checked={v.checked} />
                          <span class="chip peer-checked:border-line-strong peer-checked:text-ink-text peer-disabled:opacity-40 peer-disabled:line-through">
                            {v.label}
                            {v.stock > 0 && v.stock <= 3 && <span class="ml-1 text-ink-faint">· son {v.stock}</span>}
                          </span>
                        </label>
                      ))}
                    </div>
                  </fieldset>
                )}

                <div class="grid grid-cols-2 gap-3">
                  <label class="block">
                    <span class="block text-sm text-ink-dim mb-1.5">Ad Soyad</span>
                    <input type="text" name="buyerName" required autocomplete="name" class={inputCls} />
                  </label>
                  <label class="block">
                    <span class="block text-sm text-ink-dim mb-1.5">Adet</span>
                    <input type="number" name="qty" value="1" min="1" max="5" class={inputCls} />
                  </label>
                </div>

                <label class="block">
                  <span class="block text-sm text-ink-dim mb-1.5">E-posta</span>
                  <input type="email" name="buyerEmail" required autocomplete="email" placeholder="seni@bul.alim" class={inputCls} />
                  <span class="block text-xs text-ink-faint mt-1.5">Onay ve teslim detaylarını buraya göndereceğiz.</span>
                </label>

                <button type="submit" class="btn btn-primary w-full justify-center">
                  <Icon name="shopping-bag" size={16} /> Sipariş oluştur
                </button>
              </form>
            )
          }

          <p class="mt-4 pt-4 border-t border-line-soft text-xs text-ink-faint inline-flex flex-wrap items-center gap-2">
            <Icon name="mail" size={14} />
            {STORE.fulfilmentNote}
          </p>
        </div>
      </div>
    </div>
  </section>

  <AsciiReveal />

  <script is:inline define:vars={{ pv: productView }}>
    (function () {
      // Re-runs on each view-transition navigation, so the view fires once per
      // product page; listeners bind to this page's (fresh) form element.
      try { window.track && window.track("store_product_view", pv); } catch (e) {}
      var form = document.querySelector('form[action="/api/store/reserve"]');
      if (!form) return;
      var qty = form.querySelector('input[name="qty"]');
      function variant() {
        var r = form.querySelector('input[name="variantId"]:checked');
        var label = r ? ((r.closest("label") || {}).innerText || "").trim() : "";
        return { id: r ? r.value : "", label: label };
      }
      form.addEventListener("change", function (e) {
        if (e.target && (e.target.name === "variantId" || e.target.name === "qty")) {
          var v = variant();
          try {
            window.track && window.track("store_variant_select", {
              product_id: pv.product_id, variant_id: v.id, variant_label: v.label,
              qty: Number((qty && qty.value) || 1),
            });
          } catch (err) {}
        }
      });
      form.addEventListener("submit", function () {
        var v = variant();
        try {
          window.track && window.track("store_reserve_submit", {
            product_id: pv.product_id, product_name: pv.product_name, variant_id: v.id,
            qty: Number((qty && qty.value) || 1), price_minor: pv.price_minor,
          });
        } catch (err) {}
      });
    })();
  </script>
</BaseLayout>
