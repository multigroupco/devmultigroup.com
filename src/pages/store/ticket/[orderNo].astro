---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";
import { getEnv } from "@/lib/runtime";
import { getOrderByNo, getOrderItems } from "@/lib/store/orders";
import { money } from "@/lib/store/format";
import { STORE } from "@/lib/store/config";

const env = getEnv(Astro.locals);
const { orderNo = "" } = Astro.params;
const order = await getOrderByNo(env, orderNo);
if (!order) return Astro.redirect("/store");

const items = await getOrderItems(env, order.id);

const STATUS: Record<string, string> = { reserved: "Alındı", paid: "Ödendi", delivered: "Teslim edildi", cancelled: "İptal edildi" };
const PAY: Record<string, string> = { unpaid: "Ödeme bekleniyor", paid: "Ödendi", refunded: "İade edildi" };
---

<BaseLayout title={`Sipariş ${order.order_no}`} description="Sipariş özeti" canonicalPath={`/store/ticket/${order.order_no}`} noindex={true}>
  <section class="container-x pt-14 md:pt-20 pb-24 max-w-xl">
    <div class="text-center mb-8">
      <span class="grid place-items-center w-14 h-14 rounded-full bg-white/5 mx-auto mb-4">
        <Icon name="check" size={24} class="text-grad" />
      </span>
      <h1 class="text-2xl md:text-3xl font-semibold">Siparişin alındı! 🎉</h1>
      <p class="text-ink-dim mt-2 text-sm">Bu sayfa sipariş özetin. E-postana da gönderdik.</p>
    </div>

    <!-- monochrome receipt -->
    <div class="card p-6 font-mono text-sm">
      <div class="flex items-center justify-between pb-4 border-b border-line-soft">
        <span class="text-ink-faint text-xs uppercase tracking-widest">Sipariş No</span>
        <span class="text-grad text-lg tabular-nums">{order.order_no}</span>
      </div>

      <div class="py-4 space-y-2 border-b border-line-soft">
        {
          items.map((it) => (
            <div class="flex items-start justify-between gap-3">
              <span class="text-ink-dim">
                {it.snapshot_name}
                {it.snapshot_variant && <span class="text-ink-faint"> · {it.snapshot_variant}</span>}
                <span class="text-ink-faint"> ×{it.qty}</span>
              </span>
              <span class="tabular-nums text-ink-text shrink-0">{money(it.line_total_minor)}</span>
            </div>
          ))
        }
      </div>

      <div class="py-4 space-y-1.5 border-b border-line-soft text-ink-dim">
        <div class="flex justify-between"><span>Ara toplam</span><span class="tabular-nums">{money(order.subtotal_minor)}</span></div>
        <div class="flex justify-between text-ink-faint"><span>KDV (dahil)</span><span class="tabular-nums">{money(order.vat_minor)}</span></div>
        <div class="flex justify-between text-ink-text text-base pt-1.5"><span>Toplam</span><span class="text-grad tabular-nums">{money(order.total_minor)}</span></div>
      </div>

      <dl class="pt-4 space-y-2 text-xs">
        <div class="flex justify-between"><dt class="text-ink-faint">Durum</dt><dd class="text-ink-text">{STATUS[order.status]}</dd></div>
        <div class="flex justify-between"><dt class="text-ink-faint">Ödeme</dt><dd class="text-ink-text">{PAY[order.payment_status]}</dd></div>
        <div class="flex justify-between"><dt class="text-ink-faint">Ad</dt><dd class="text-ink-text">{order.buyer_name}</dd></div>
      </dl>
    </div>

    <p class="text-center text-xs text-ink-faint mt-6">{STORE.fulfilmentNote}</p>
    <div class="text-center mt-6">
      <a href="/store" class="btn btn-ghost">Mağazaya dön</a>
    </div>
  </section>
</BaseLayout>
