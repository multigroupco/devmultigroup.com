---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";
import { tryEnv } from "@/lib/runtime";
import { listSpeakers, listCompanies } from "@/lib/content";
import { imageSrc } from "@/lib/ui";
import { BRAND } from "@/lib/site";
import type { SpeakerRow, CompanyRow, SpeakerSocials } from "@/lib/types";

const env = tryEnv(Astro.locals);
let speakers: SpeakerRow[] = [];
let companies: CompanyRow[] = [];
if (env) {
  try {
    [speakers, companies] = await Promise.all([listSpeakers(env, { limit: 1000 }), listCompanies(env)]);
  } catch {
    /* pre-seed */
  }
}
const byId = new Map(companies.map((c) => [c.id, c]));
const co = (s: SpeakerRow) => (s.company_id ? byId.get(s.company_id) : null);

const totalTalks = speakers.reduce((a, s) => a + (s.talk_count || 0), 0);
const companyCount = new Set(speakers.map((s) => s.company_id).filter(Boolean)).size;

const sectors = [
  ...new Set(speakers.map((s) => co(s)?.sector).filter((x): x is string => Boolean(x))),
].sort((a, b) => a.localeCompare(b, "tr"));

const initials = (name: string) =>
  name.split(/\s+/).filter(Boolean).slice(0, 2).map((w) => w[0]).join("").toUpperCase();
const parseSoc = (raw: string): SpeakerSocials => {
  try { return raw ? JSON.parse(raw) : {}; } catch { return {}; }
};
const socList = (s: SpeakerRow) => {
  const x = parseSoc(s.socials);
  return ([["linkedin", x.linkedin], ["github", x.github], ["twitter", x.twitter], ["globe", x.website]] as const)
    .filter((p): p is [(typeof p)[0], string] => Boolean(p[1]));
};

// featured = has a photo + a title, most prolific first
const featured = speakers
  .filter((s) => s.avatar_url && s.title)
  .sort((a, b) => b.talk_count - a.talk_count || a.name.localeCompare(b.name, "tr"))
  .slice(0, 12);

const speakersLd = speakers.length
  ? {
      "@context": "https://schema.org",
      "@type": "ItemList",
      name: "Developer MultiGroup konuşmacıları",
      numberOfItems: speakers.length,
      itemListElement: speakers.slice(0, 100).map((s, i) => ({
        "@type": "ListItem",
        position: i + 1,
        item: { "@type": "Person", name: s.name, ...(s.title ? { jobTitle: s.title } : {}), ...(s.company ? { worksFor: { "@type": "Organization", name: s.company } } : {}) },
      })),
    }
  : undefined;
---

<BaseLayout
  title="Konuşmacılar"
  description="6 yılda Developer MultiGroup sahnesinde yer alan konuşmacılar — mühendisler, takım liderleri, kurucular ve araştırmacılar. Yüzlerce talk, tek bir topluluk."
  canonicalPath="/speakers"
  jsonLd={speakersLd}
  breadcrumbs={[{ name: "Konuşmacılar", item: `${BRAND.url}/speakers` }]}
>
  <!-- hero -->
  <section class="container-x pt-14 pb-7">
    <p class="text-sm text-ink-faint uppercase tracking-[0.18em] mb-4">Ekosistem · Konuşmacılar</p>
    <div class="grid lg:grid-cols-[1fr_auto] gap-8 lg:gap-16 lg:items-end">
      <h1 class="text-4xl md:text-6xl font-semibold leading-[1.02] max-w-3xl">
        Sahnemizi paylaşan <span class="text-grad">{speakers.length} isim</span>.
      </h1>
      <div class="flex gap-8 shrink-0">
        <div><div class="font-display text-3xl md:text-4xl font-semibold tabular-nums">{speakers.length}</div><div class="text-ink-faint text-[0.7rem] mt-1 font-mono uppercase tracking-wider">konuşmacı</div></div>
        <div><div class="font-display text-3xl md:text-4xl font-semibold tabular-nums">{totalTalks}</div><div class="text-ink-faint text-[0.7rem] mt-1 font-mono uppercase tracking-wider">konuşma</div></div>
        <div><div class="font-display text-3xl md:text-4xl font-semibold tabular-nums">{companyCount}</div><div class="text-ink-faint text-[0.7rem] mt-1 font-mono uppercase tracking-wider">şirket</div></div>
      </div>
    </div>
    <p class="text-ink-dim mt-6 max-w-2xl leading-relaxed">
      İlk günden bugüne bilgisini ve deneyimini topluluğumuzla paylaşan herkes. Hepsine
      teşekkür ederiz — bu sahne onların.
    </p>
  </section>

  {
    featured.length >= 4 && (
      <section class="container-x pb-3">
        <h2 class="text-[0.7rem] font-mono uppercase tracking-[0.18em] text-ink-faint mb-4">Öne çıkanlar</h2>
        <div class="flex gap-3 overflow-x-auto pb-2 -mx-1 px-1 no-scrollbar snap-x">
          {featured.map((s) => {
            const c = co(s);
            return (
              <div class="snap-start shrink-0 w-60 card card-hover p-4">
                <div class="w-14 h-14 rounded-full overflow-hidden bg-white/[0.05] border border-line grid place-items-center mb-3">
                  <img src={imageSrc(s.avatar_url)} alt={s.name} loading="lazy" class="w-full h-full object-cover" />
                </div>
                <h3 class="font-medium leading-snug">{s.name}</h3>
                <p class="text-ink-dim text-xs mt-1 leading-snug line-clamp-2">{s.title}</p>
                <div class="mt-2.5 flex items-center gap-2 h-4">
                  {c?.logo_url ? <img src={imageSrc(c.logo_url)} alt={c.name} class="h-3.5 w-auto max-w-[80px] object-contain opacity-70" loading="lazy" /> : <span class="text-ink-faint text-xs truncate">{s.company}</span>}
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )
  }

  <!-- toolbar -->
  <section class="container-x pt-5">
    <div class="flex flex-col gap-4 scroll-mt-20">
      <label class="relative max-w-md">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-ink-faint pointer-events-none"><Icon name="search" size={16} /></span>
        <input id="sp-search" type="text" autocomplete="off" placeholder="Konuşmacı veya şirket ara…"
          class="w-full bg-white/[0.04] border border-line rounded-xl pl-9 pr-9 py-2.5 text-sm placeholder:text-ink-faint focus:outline-none focus:border-white/25 transition" />
        <button type="button" id="sp-search-clear" aria-label="Temizle" class="hidden absolute right-2.5 top-1/2 -translate-y-1/2 text-ink-faint hover:text-ink-text"><Icon name="close" size={15} /></button>
      </label>
      <div class="flex gap-2 overflow-x-auto pb-1 -mx-1 px-1 no-scrollbar">
        <button type="button" class="sector-pill is-active" data-sector="">Tümü <span class="tabular-nums opacity-60">{speakers.length}</span></button>
        {sectors.map((s) => <button type="button" class="sector-pill" data-sector={s}>{s}</button>)}
      </div>
    </div>
  </section>

  <!-- roster index -->
  <section class="container-x py-6">
    <ol id="sp-roster" class="border-t border-line">
      {
        speakers.map((s) => {
          const c = co(s);
          const socs = socList(s);
          return (
            <li class="sp-row group grid grid-cols-[auto_1fr_auto] sm:grid-cols-[auto_1.4fr_1fr_auto] items-center gap-x-4 gap-y-1 py-3 border-b border-line-soft hover:bg-white/[0.02] transition-colors scroll-mt-24"
              id={`s-${s.id}`} data-q={`${s.name} ${s.company} ${s.title}`.toLocaleLowerCase("tr")} data-sector={c?.sector ?? ""}>
              <div class="w-10 h-10 rounded-full overflow-hidden bg-white/[0.05] border border-line grid place-items-center shrink-0">
                {s.avatar_url ? <img src={imageSrc(s.avatar_url)} alt={s.name} loading="lazy" class="w-full h-full object-cover" /> : <span class="font-display text-xs text-ink-dim">{initials(s.name)}</span>}
              </div>
              <div class="min-w-0">
                <h3 class="font-medium leading-tight truncate">{s.name}</h3>
                {s.title && <p class="text-ink-faint text-xs mt-0.5 truncate">{s.title}</p>}
              </div>
              <div class="hidden sm:flex items-center gap-2 min-w-0">
                {c?.logo_url ? <img src={imageSrc(c.logo_url)} alt={c.name} loading="lazy" class="h-4 w-auto max-w-[110px] object-contain opacity-70" /> : <span class="text-ink-dim text-sm truncate">{s.company}</span>}
              </div>
              <div class="flex items-center gap-1 justify-end shrink-0">
                <div class="hidden md:flex items-center gap-0.5 mr-1 opacity-0 group-hover:opacity-100 transition-opacity">
                  {socs.map(([icon, url]) => (
                    <a href={url} target="_blank" rel="noopener noreferrer" aria-label={`${s.name} · ${icon}`} class="grid place-items-center w-7 h-7 rounded-lg text-ink-faint hover:text-ink-text hover:bg-white/[0.06] transition"
                      data-track="cta_click" data-track-props={JSON.stringify({ cta_id: `speaker_social_${icon}`, name: s.name, page: "speakers" })}>
                      <Icon name={icon} size={14} />
                    </a>
                  ))}
                </div>
                {s.talk_count > 0 && <span class="text-ink-faint text-xs font-mono tabular-nums w-12 text-right">{s.talk_count} ×</span>}
              </div>
            </li>
          );
        })
      }
    </ol>
    <p id="sp-empty" class="hidden text-center text-ink-faint text-sm py-12">
      Eşleşen konuşmacı yok. <button type="button" data-clear-all class="underline hover:text-ink-text">Temizle</button>
    </p>
  </section>

  <style>
    .sp-row.is-hidden { display: none; }
    .sector-pill { flex: none; display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.4rem 0.8rem; border-radius: 999px; font-size: 0.8rem; white-space: nowrap; color: var(--color-ink-dim); border: 1px solid var(--color-line); background: rgba(255,255,255,0.02); transition: all 0.15s var(--ease-out-soft); cursor: pointer; }
    .sector-pill:hover { color: var(--color-ink-text); border-color: rgba(255,255,255,0.2); }
    .sector-pill.is-active { color: #000; background: #fff; border-color: #fff; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { scrollbar-width: none; }
  </style>

  <script is:inline>
    (() => {
      const init = () => {
        const roster = document.getElementById("sp-roster");
        const search = document.getElementById("sp-search");
        if (!roster || !search || roster.dataset.bound) return;
        roster.dataset.bound = "1";
        const rows = Array.from(roster.querySelectorAll(".sp-row"));
        const pills = Array.from(document.querySelectorAll(".sector-pill"));
        const clearBtn = document.getElementById("sp-search-clear");
        const empty = document.getElementById("sp-empty");
        const state = { sector: "", q: "" };
        const norm = (s) => (s || "").toLocaleLowerCase("tr").trim();
        const apply = () => {
          let total = 0;
          rows.forEach((r) => {
            const ok = (!state.sector || r.dataset.sector === state.sector) && (!state.q || (r.dataset.q || "").includes(state.q));
            r.classList.toggle("is-hidden", !ok); if (ok) total++;
          });
          if (empty) empty.classList.toggle("hidden", total !== 0);
          if (clearBtn) clearBtn.classList.toggle("hidden", !search.value);
        };
        let deb;
        search.addEventListener("input", () => {
          state.q = norm(search.value); apply();
          clearTimeout(deb);
          deb = setTimeout(() => { const q = state.q.trim(); if (q.length < 2) return; try { window.track && window.track("search_submit", { query: q, result_count: roster.querySelectorAll(".sp-row:not(.is-hidden)").length, surface: "speakers" }); } catch (e) {} }, 400);
        });
        if (clearBtn) clearBtn.addEventListener("click", () => { search.value = ""; state.q = ""; apply(); search.focus(); });
        pills.forEach((p) => p.addEventListener("click", () => { pills.forEach((x) => x.classList.remove("is-active")); p.classList.add("is-active"); state.sector = p.dataset.sector || ""; apply(); }));
        const clearAll = document.querySelector("[data-clear-all]");
        if (clearAll) clearAll.addEventListener("click", () => { state.sector = ""; state.q = ""; search.value = ""; pills.forEach((x) => x.classList.toggle("is-active", !x.dataset.sector)); apply(); });
        apply();
      };
      if (!window.__dmgSpRoster) { window.__dmgSpRoster = true; document.addEventListener("astro:page-load", init); }
      init();
    })();
  </script>
</BaseLayout>
