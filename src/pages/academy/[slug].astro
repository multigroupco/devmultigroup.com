---
import EventDetail from "@/components/EventDetail.astro";
import { getEnv } from "@/lib/runtime";
import { getEvent } from "@/lib/content";

const env = getEnv(Astro.locals);
const { slug } = Astro.params;
const event = slug ? await getEvent(env, slug) : null;

// Only academy events belong here; MultiGroup events live under /events/<slug>.
if (event && event.community !== "multiacademy") {
  return Astro.redirect(`/events/${event.slug}`, 301);
}
if (!event) Astro.response.status = 404;
---

<EventDetail event={event} />
