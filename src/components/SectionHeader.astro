---
import Icon from "./Icon.astro";
interface Props {
  title: string;
  description?: string;
  href?: string;
  hrefLabel?: string;
  align?: "left" | "center";
}
const { title, description, href, hrefLabel = "View all", align = "left" } = Astro.props;
---

<div class:list={["flex flex-wrap items-end gap-4 justify-between", align === "center" && "flex-col items-center text-center"]}>
  <div class:list={[align === "center" && "max-w-2xl"]}>
    <h2 class="text-3xl md:text-4xl font-semibold">{title}</h2>
    {description && <p class="text-ink-dim mt-3 max-w-xl leading-relaxed">{description}</p>}
  </div>
  {
    href && (
      <a href={href} class="group inline-flex items-center gap-1.5 text-sm text-ink-dim hover:text-ink-text transition-colors shrink-0">
        {hrefLabel}
        <Icon name="arrow-right" size={16} class="transition-transform group-hover:translate-x-0.5" />
      </a>
    )
  }
</div>
