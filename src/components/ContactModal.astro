---
import Icon from "./Icon.astro";
---

<div id="contact-modal" class="contact-modal" aria-hidden="true">
  <div class="contact-backdrop" data-close></div>
  <div class="contact-card" role="dialog" aria-modal="true" aria-labelledby="contact-title">
    <button type="button" class="contact-x" data-close aria-label="Kapat">
      <Icon name="close" size={18} />
    </button>
    <h3 id="contact-title" class="font-display text-xl font-semibold pr-8">Bize ulaş</h3>
    <p id="contact-sub" class="text-ink-dim text-sm mt-1.5">Bilgilerini bırak, en kısa sürede dönelim.</p>

    <form id="contact-form" class="mt-5 space-y-3.5">
      <input type="hidden" name="type" value="support" />
      <input type="text" name="company_website" class="contact-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <div data-field="name">
        <label class="contact-label" for="cf-name">Ad Soyad</label>
        <input id="cf-name" name="name" maxlength="200" class="contact-input" placeholder="Adın" />
      </div>
      <div data-field="email">
        <label class="contact-label" for="cf-email">E-posta</label>
        <input id="cf-email" name="email" type="email" maxlength="200" class="contact-input" placeholder="ornek@eposta.com" />
      </div>
      <div data-field="org">
        <label class="contact-label" for="cf-org">Şirket / Topluluk <span class="text-ink-faint">(opsiyonel)</span></label>
        <input id="cf-org" name="org" maxlength="200" class="contact-input" placeholder="Kurum adı" />
      </div>
      <div data-field="message">
        <label class="contact-label" for="cf-msg">Mesaj</label>
        <textarea id="cf-msg" name="message" maxlength="5000" rows="4" class="contact-input" placeholder="Bize biraz bahset…"></textarea>
      </div>
      <button type="submit" class="btn btn-primary w-full justify-center" id="contact-submit">
        <Icon name="mail" size={16} /> <span id="contact-submit-label">Gönder</span>
      </button>
      <p id="contact-status" class="contact-status" role="status" aria-live="polite"></p>
    </form>

    <div id="contact-success" class="contact-success" hidden>
      <div class="contact-check"><Icon name="check" size={26} /></div>
      <h4 id="contact-success-title" class="font-display text-lg font-semibold mt-3">Teşekkürler!</h4>
      <p id="contact-success-text" class="text-ink-dim text-sm mt-1.5">Mesajın bize ulaştı — en kısa sürede döneceğiz.</p>
      <button type="button" class="btn btn-ghost mt-5 justify-center" data-close>Kapat</button>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const SUCCESS = { title: "Teşekkürler!", text: "Mesajın bize ulaştı — en kısa sürede döneceğiz." };
    const TYPES = {
      partner: { title: "Partner ol", sub: "Topluluğunu ağa katmak için bilgilerini bırak." },
      sponsor: { title: "Sponsor ol", sub: "Markanı topluluğa taşımak için bize ulaş." },
      support: { title: "Bize ulaş", sub: "Soru ve taleplerini ilet, en kısa sürede dönelim." },
      newsletter: {
        title: "Bültene abone ol",
        sub: "Yeni etkinlik ve duyurulardan ilk sen haberdar ol.",
        newsletter: true,
        submit: "Abone ol",
        success: { title: "Aramızdasın! 🎉", text: "Bültene abone oldun — yeni içeriklerden ilk sen haberdar olacaksın." },
      },
    };
    const m = () => document.getElementById("contact-modal");
    function open(type) {
      const el = m();
      if (!el) return;
      const t = TYPES[type] || TYPES.support;
      const isNews = !!t.newsletter;
      const form = el.querySelector("#contact-form");
      form.reset();
      form.hidden = false;
      form.querySelector('input[name="type"]').value = type;
      el.querySelector("#contact-title").textContent = t.title;
      el.querySelector("#contact-sub").textContent = t.sub;
      el.querySelector("#contact-success").hidden = true;
      const required = isNews ? ["email"] : ["name", "email", "message"];
      el.querySelectorAll("[data-field]").forEach((w) => {
        const f = w.getAttribute("data-field");
        const show = isNews ? f === "email" : true;
        w.hidden = !show;
        const inp = w.querySelector("input, textarea");
        if (inp) inp.required = show && required.includes(f);
      });
      el.querySelector("#contact-submit-label").textContent = t.submit || "Gönder";
      const sc = t.success || SUCCESS;
      el.querySelector("#contact-success-title").textContent = sc.title;
      el.querySelector("#contact-success-text").textContent = sc.text;
      const status = el.querySelector("#contact-status");
      status.textContent = "";
      status.className = "contact-status";
      el.classList.add("open");
      el.setAttribute("aria-hidden", "false");
      document.getElementById("mobile-nav")?.classList.remove("open");
      document.documentElement.style.overflow = "hidden";
      setTimeout(() => el.querySelector(isNews ? "#cf-email" : 'input[name="name"]').focus(), 60);
    }
    function close() {
      const el = m();
      if (!el) return;
      el.classList.remove("open");
      el.setAttribute("aria-hidden", "true");
      document.documentElement.style.overflow = "";
    }
    if (!window.__dmgContact) {
      window.__dmgContact = true;
      document.addEventListener("click", (e) => {
        const trigger = e.target.closest("[data-contact]");
        if (trigger) { e.preventDefault(); open(trigger.getAttribute("data-contact")); return; }
        if (e.target.closest("[data-close]")) close();
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && m()?.classList.contains("open")) close();
      });
      document.addEventListener("submit", async (e) => {
        if (e.target.id !== "contact-form") return;
        e.preventDefault();
        const el = m();
        const form = e.target;
        const status = el.querySelector("#contact-status");
        const btn = el.querySelector("#contact-submit");
        status.textContent = "";
        status.className = "contact-status";
        btn.disabled = true;
        btn.classList.add("is-loading");
        try {
          const payload = Object.fromEntries(new FormData(form).entries());
          const endpoint = payload.type === "newsletter" ? "/api/subscribe" : "/api/contact";
          const r = await fetch(endpoint, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          const j = await r.json().catch(() => ({ ok: false }));
          if (j.ok) {
            if (window.dmgTrack) {
              window.dmgTrack(
                payload.type === "newsletter" ? "newsletter_signup" : "generate_lead",
                { form_type: payload.type || "contact" },
              );
            }
            const card = el.querySelector(".contact-card");
            const success = el.querySelector("#contact-success");
            const startH = card.offsetHeight;
            form.hidden = true;
            success.hidden = false;
            const endH = card.offsetHeight;
            success.style.opacity = "0";
            card.style.height = startH + "px";
            card.getBoundingClientRect();
            card.style.transition = "height 0.45s cubic-bezier(0.22,1,0.36,1)";
            card.style.height = endH + "px";
            requestAnimationFrame(() => {
              success.style.transition = "opacity 0.4s ease 0.12s";
              success.style.opacity = "1";
            });
            setTimeout(() => {
              card.style.height = "";
              card.style.transition = "";
              const chk = el.querySelector(".contact-check");
              const rc = (chk || card).getBoundingClientRect();
              partyPopper(rc.left + rc.width / 2, rc.top + rc.height / 2);
            }, 470);
          } else {
            status.textContent = j.error || "Bir şeyler ters gitti, tekrar dene.";
            status.classList.add("is-error");
          }
        } catch {
          status.textContent = "Bağlantı hatası, lütfen tekrar dene.";
          status.classList.add("is-error");
        } finally {
          btn.disabled = false;
          btn.classList.remove("is-loading");
        }
      });
    }
    function partyPopper(x, y) {
      const c = document.createElement("canvas");
      c.style.cssText = "position:fixed;inset:0;pointer-events:none;z-index:200;";
      document.body.appendChild(c);
      const ctx = c.getContext("2d");
      const vw = window.innerWidth, vh = window.innerHeight;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      c.width = vw * dpr; c.height = vh * dpr; ctx.scale(dpr, dpr);
      const colors = ["#ffffff", "#7fe0ad", "#4ade80", "#c8c8cf", "#e8e8eb", "#86868b"];
      const P = [];
      for (let i = 0; i < 110; i++) {
        const a = Math.random() * Math.PI * 2, sp = 5 + Math.random() * 10;
        P.push({ x, y, vx: Math.cos(a) * sp, vy: Math.sin(a) * sp - 5, w: 4 + Math.random() * 5, h: 6 + Math.random() * 7, color: colors[(Math.random() * colors.length) | 0], rot: Math.random() * Math.PI, vr: (Math.random() - 0.5) * 0.5, life: 1 });
      }
      let t = 0;
      (function loop() {
        ctx.clearRect(0, 0, vw, vh);
        let alive = false;
        for (const p of P) {
          p.vx *= 0.99; p.vy = p.vy * 0.99 + 0.25; p.x += p.vx; p.y += p.vy; p.rot += p.vr; p.life -= 0.011;
          if (p.life > 0 && p.y < vh + 30) {
            alive = true;
            ctx.save(); ctx.globalAlpha = Math.max(0, Math.min(1, p.life)); ctx.translate(p.x, p.y); ctx.rotate(p.rot);
            ctx.fillStyle = p.color; ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
            ctx.restore();
          }
        }
        if (alive && ++t < 220) requestAnimationFrame(loop); else c.remove();
      })();
    }
  })();
</script>
