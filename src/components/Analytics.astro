---
// Google Analytics 4 — renders only when a measurement id is configured
// (settings.ga_measurement_id). Set that one value and analytics goes live.
//
// SPA-aware: the site uses Astro's <ClientRouter/> (view transitions), so most
// navigations are client-side and gtag's automatic page_view would only fire on
// the very first load. We disable the auto pageview (send_page_view:false) and
// emit one manually on every `astro:page-load` (fires on initial load AND each
// view transition) — exactly one page_view per page, no under/over-counting.
//
// Also exposes `window.dmgTrack(name, params)` (a gtag-safe no-op when GA is off)
// and a delegated click tracker for any element carrying a `data-ga="<event>"`
// attribute (optional JSON in `data-ga-params`). Used for conversion events.
interface Props {
  measurementId?: string;
}
const { measurementId } = Astro.props;
---

{
  measurementId && (
    <>
      <link rel="preconnect" href="https://www.googletagmanager.com" />
      <script
        is:inline
        async
        src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`}
      />
      <script is:inline define:vars={{ measurementId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        window.gtag = window.gtag || gtag;
        window.dmgTrack = function (name, params) {
          try {
            window.gtag("event", name, params || {});
          } catch (e) {}
        };
        if (!window.__dmgGA) {
          window.__dmgGA = true;
          gtag("js", new Date());
          // Disable the automatic first pageview; we send every pageview manually
          // so client-side (view transition) navigations are all counted.
          gtag("config", measurementId, {
            anonymize_ip: true,
            send_page_view: false,
          });
          var pageview = function () {
            gtag("event", "page_view", {
              page_location: location.href,
              page_path: location.pathname + location.search,
              page_title: document.title,
            });
          };
          // Fires on initial load and after each Astro view transition.
          document.addEventListener("astro:page-load", pageview);
          // Declarative conversion tracking: <a data-ga="join_click" data-ga-params='{"x":1}">
          document.addEventListener("click", function (e) {
            var t = e.target.closest && e.target.closest("[data-ga]");
            if (!t) return;
            var params = {};
            var raw = t.getAttribute("data-ga-params");
            if (raw) {
              try {
                params = JSON.parse(raw);
              } catch (err) {}
            }
            window.dmgTrack(t.getAttribute("data-ga"), params);
          });
        }
      </script>
    </>
  )
}
