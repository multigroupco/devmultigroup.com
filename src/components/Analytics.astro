---
// Unified analytics + observability bootstrap for the whole site.
//
// Renders ONE consent-aware inline bootstrap in <head> that wires three tools:
//   • Google Analytics 4  — marketing/traffic + conversions (gtag)
//   • PostHog             — product analytics, autocapture, web vitals, replay
//   • Sentry (browser)    — JS error monitoring (loaded via the JS Loader)
//
// Design notes:
//   • window.track(name, props) is the ONE dispatcher. It fans out to BOTH GA4
//     and PostHog. window.dmgTrack is kept as a back-compat alias (it used to be
//     GA-only) so nothing that already calls it regresses.
//   • A delegated document click listener fires track() for any element carrying
//     data-track="event" (+ optional data-track-props='{json}'). The legacy
//     data-ga / data-ga-params attributes are still honoured by the SAME listener
//     so existing markup keeps working — track() is a strict superset of the old
//     GA wiring.
//   • SPA-aware: the site uses <ClientRouter/> view transitions. gtag's auto
//     pageview is disabled (send_page_view:false) and PostHog's too
//     (capture_pageview:false); we emit exactly one page_view / $pageview per
//     page on every `astro:page-load` (fires on first load AND each transition).
//   • Consent: OPT-OUT model (KVKK/GDPR). Analytics (GA + PostHog) load by
//     default unless the visitor sends Do-Not-Track or has previously rejected.
//     A dismissible banner (<ConsentBanner/>, in <body>) lets them reject, which
//     disables GA (ga-disable flag) and opts PostHog out + stops replay. Sentry
//     is treated as essential error monitoring (no PII) and loads regardless.
//   • A master switch (settings.analytics_enabled) renders nothing when off.
interface Props {
  measurementId?: string;
  posthogKey?: string;
  posthogHost?: string;
  sentryDsn?: string;
  environment?: string;
  release?: string;
  enabled?: boolean;
}
const {
  measurementId = "",
  posthogKey = "",
  posthogHost = "https://us.i.posthog.com",
  sentryDsn = "",
  environment = "production",
  release = "",
  enabled = true,
} = Astro.props;

// Derive the Sentry browser Loader URL from the public key in the DSN.
let sentryLoader = "";
try {
  if (sentryDsn) {
    const u = new URL(sentryDsn);
    if (u.username) sentryLoader = `https://js.sentry-cdn.com/${u.username}.min.js`;
  }
} catch { /* malformed DSN → no client Sentry */ }

const phAssets = posthogHost.replace(".i.posthog.com", "-assets.i.posthog.com");
const A = {
  enabled,
  ga: measurementId,
  phKey: posthogKey,
  phHost: posthogHost.replace(/\/$/, ""),
  sentryLoader,
  sentryEnv: environment,
  sentryRelease: release,
};
const active = enabled && (measurementId || posthogKey || sentryLoader);
---

{
  active && (
    <>
      {measurementId && <link rel="preconnect" href="https://www.googletagmanager.com" />}
      {posthogKey && <link rel="preconnect" href={posthogHost} crossorigin />}
      {posthogKey && <link rel="preconnect" href={phAssets} crossorigin />}
      {sentryLoader && <link rel="preconnect" href="https://js.sentry-cdn.com" crossorigin />}
      <script is:inline define:vars={{ A }}>
        (function () {
  if (!A.enabled) return;
  var w = window, d = document;

  /* ---------- consent (opt-out model) ---------- */
  var CK = "dmg_consent"; // "granted" | "denied"
  function dnt() {
    var v = navigator.doNotTrack || w.doNotTrack || navigator.msDoNotTrack;
    return v === "1" || v === "yes";
  }
  function read() { try { return localStorage.getItem(CK); } catch (e) { return null; } }
  function write(v) { try { localStorage.setItem(CK, v); } catch (e) {} }
  var choice = read();
  var analytics = choice ? choice === "granted" : !dnt();
  w.__dmgConsent = analytics ? "granted" : "denied";

  /* ---------- GA4 ---------- */
  function loadGA() {
    if (!A.ga || w.__dmgGA) return;
    w.__dmgGA = true;
    w.dataLayer = w.dataLayer || [];
    function gtag() { w.dataLayer.push(arguments); }
    w.gtag = w.gtag || gtag;
    var s = d.createElement("script");
    s.async = true; s.src = "https://www.googletagmanager.com/gtag/js?id=" + A.ga;
    d.head.appendChild(s);
    w.gtag("js", new Date());
    w.gtag("config", A.ga, { anonymize_ip: true, send_page_view: false });
  }
  function disableGA() { if (A.ga) w["ga-disable-" + A.ga] = true; }

  /* ---------- PostHog ---------- */
  function loadPH() {
    if (!A.phKey || w.__dmgPH) return;
    w.__dmgPH = true;
    !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister unregister_for_session getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty createPersonProfile opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug getPageViewId captureTraceFeedback captureTraceMetric".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(d,w.posthog||[]);
    w.posthog.init(A.phKey, {
      api_host: A.phHost,
      ui_host: "https://us.posthog.com",
      defaults: "2025-05-24",
      capture_pageview: false,
      capture_pageleave: true,
      autocapture: true,
      person_profiles: "identified_only",
      persistence: "localStorage+cookie"
    });
  }
  function disablePH() {
    try {
      if (w.posthog && w.posthog.opt_out_capturing) {
        w.posthog.opt_out_capturing();
        if (w.posthog.stopSessionRecording) w.posthog.stopSessionRecording();
      }
    } catch (e) {}
  }

  /* ---------- Sentry (essential: errors, loads regardless of analytics consent) ---------- */
  function loadSentry() {
    if (!A.sentryLoader || w.__dmgSentry) return;
    w.__dmgSentry = true;
    w.sentryOnLoad = function () {
      try {
        w.Sentry.init({
          environment: A.sentryEnv,
          release: A.sentryRelease || undefined,
          tracesSampleRate: 0,
          replaysSessionSampleRate: 0,
          replaysOnErrorSampleRate: 0
        });
      } catch (e) {}
    };
    var s = d.createElement("script");
    s.async = true; s.crossOrigin = "anonymous"; s.src = A.sentryLoader;
    d.head.appendChild(s);
  }

  /* ---------- unified dispatcher: GA4 + PostHog ---------- */
  function fire(name, props) {
    if (w.__dmgConsent === "denied") return;
    props = props || {};
    try { if (w.gtag) w.gtag("event", name, props); } catch (e) {}
    try { if (w.posthog && w.posthog.capture) w.posthog.capture(name, props); } catch (e) {}
  }
  w.track = fire;
  w.dmgTrack = fire; // back-compat (was GA-only)

  /* ---------- pageview, once per page-load incl. view transitions ---------- */
  function pageview() {
    if (w.__dmgConsent === "denied") return;
    try { if (w.gtag) w.gtag("event", "page_view", {
      page_location: location.href,
      page_path: location.pathname + location.search,
      page_title: d.title
    }); } catch (e) {}
    try { if (w.posthog && w.posthog.capture) w.posthog.capture("$pageview", { $current_url: location.href }); } catch (e) {}
  }

  /* ---------- delegated click tracking: [data-track] + legacy [data-ga] ---------- */
  function onClick(e) {
    var t = e.target.closest && e.target.closest("[data-track],[data-ga]");
    if (!t) return;
    var name = t.getAttribute("data-track") || t.getAttribute("data-ga");
    if (!name) return;
    var raw = t.getAttribute("data-track-props") || t.getAttribute("data-ga-params");
    var props = {};
    if (raw) { try { props = JSON.parse(raw); } catch (err) {} }
    fire(name, props);
  }

  /* ---------- consent banner (rendered in <body> by ConsentBanner.astro) ---------- */
  function banner() { return d.getElementById("dmg-consent"); }
  function maybeShowBanner() {
    var b = banner(); if (!b) return;
    if (read() === null && !dnt()) b.removeAttribute("hidden");
    else b.setAttribute("hidden", "");
  }
  function onConsentClick(e) {
    var btn = e.target.closest && e.target.closest("[data-consent]");
    if (!btn) return;
    var v = btn.getAttribute("data-consent"); // "granted" | "denied"
    write(v);
    w.__dmgConsent = v;
    if (v === "granted") { loadGA(); loadPH(); pageview(); }
    else { disableGA(); disablePH(); }
    var b = banner(); if (b) b.setAttribute("hidden", "");
  }

  /* ---------- init ---------- */
  if (analytics) loadGA(); else disableGA();
  if (analytics) loadPH();
  loadSentry();

  if (!w.__dmgAnalyticsBound) {
    w.__dmgAnalyticsBound = true;
    d.addEventListener("astro:page-load", function () { pageview(); maybeShowBanner(); });
    d.addEventListener("click", onClick);
    d.addEventListener("click", onConsentClick);
  }
})();
      </script>
    </>
  )
}
