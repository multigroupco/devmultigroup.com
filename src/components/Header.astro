---
import Icon from "./Icon.astro";
import { NAV, BRAND, JOIN_FORM } from "@/lib/site";

interface Props {
  variant?: "multigroup" | "academy" | "store";
}
const { variant = "multigroup" } = Astro.props;

// brand variants — same collapse/spin logic, just different mark + wordmark.
// w = full display width (px), wordLeft = where the wordmark begins (mark slot).
// `store` reuses the MultiGroup flower (identical mark + spin) but renders a text
// wordmark ("Multi" bold + "Store" light) matching the dmg-logo two-weight style.
const BRANDS = {
  multigroup: { name: BRAND.name, href: "/", mark: "/logo-small-white.png", word: "/dmg-logo.webp", w: 160, wordLeft: 28, h: 28, spin: 180, wordText: { strong: "Multi", rest: "Group" }, wordSize: "1.39rem" },
  academy: { name: "MultiAcademy", href: "/", mark: "/logo-small-white.png", word: "/dmg-logo.webp", w: 190, wordLeft: 28, h: 28, spin: 180, wordText: { strong: "Multi", rest: "Academy" }, wordSize: "1.39rem" },
  store: { name: "MultiStore", href: "/", mark: "/logo-small-white.png", word: "/dmg-logo.webp", w: 158, wordLeft: 28, h: 28, spin: 180, wordText: { strong: "Multi", rest: "Store" }, wordSize: "1.39rem" },
} as const;
const brand = BRANDS[variant];
const wordText = "wordText" in brand ? brand.wordText : null;
const wordSize = "wordSize" in brand ? brand.wordSize : "1.36rem";

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header id="site-header" class="site-header">
  <div class="container-x flex items-center justify-between gap-4 h-16">
    <a href={brand.href} class="brand shrink-0" aria-label={brand.name} style={`--brand-w:${brand.w}px;--brand-word-left:${brand.wordLeft}px;--brand-h:${brand.h}px;--brand-spin:${brand.spin}deg;--store-word-size:${wordSize}`}>
      <span class="brand-mark">
        <img src={brand.mark} alt="" height="28" aria-hidden="true" />
      </span>
      <span class="brand-word">
        {
          wordText ? (
            <span class="brand-word-text"><b>{wordText.strong}</b>{wordText.rest}</span>
          ) : (
            <img src={brand.word} alt={brand.name} height="28" />
          )
        }
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Primary">
      {
        NAV.map((item) =>
          item.children ? (
            <div class="nav-dd">
              <a
                href={item.href}
                class:list={["nav-link inline-flex items-center gap-1", isActive(item.href) && "nav-link-active"]}
                aria-haspopup="true"
                data-track="nav_click"
                data-track-props={JSON.stringify({ location: "header", nav_label: item.label, href: item.href })}
              >
                {item.label}
                <Icon name="chevron-right" size={13} class="dd-caret" />
              </a>
              <div class="nav-dd-menu">
                <div class="nav-dd-panel">
                  {item.children.map((c) =>
                    c.soon ? (
                      <span class="nav-dd-link is-soon">
                        {c.label}
                        <span class="dd-soon">yakında</span>
                      </span>
                    ) : (
                      <a href={c.href} class:list={["nav-dd-link", isActive(c.href) && "is-current"]}>
                        {c.label}
                        <Icon name="arrow-right" size={14} class="opacity-40" />
                      </a>
                    ),
                  )}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={["nav-link", isActive(item.href) && "nav-link-active"]}
              data-track="nav_click"
              data-track-props={JSON.stringify({ location: "header", nav_label: item.label, href: item.href })}
            >
              {item.label}
            </a>
          ),
        )
      }
    </nav>

    <div class="flex items-center gap-2">
      <button type="button" data-search-open class="btn btn-ghost !rounded-xl !p-2.5" aria-label="Ara" title="Ara">
        <Icon name="search" size={16} />
      </button>
      <button type="button" data-contact="newsletter" class="btn btn-ghost hidden sm:inline-flex !rounded-xl !p-2.5" aria-label="Bültene abone ol" title="Bültene abone ol">
        <Icon name="bell" size={16} />
      </button>
      <a href={JOIN_FORM} target="_blank" rel="noopener noreferrer" class="btn btn-ghost group hidden sm:inline-flex !rounded-xl !py-2 !px-3.5 text-sm" data-track="join_click" data-track-props={JSON.stringify({ location: "header" })}>
        Aramıza katıl
        <span class="relative inline-flex w-[15px] h-[15px]">
          <Icon name="user-check" size={15} class="absolute inset-0 transition-all duration-200 group-hover:opacity-0 group-hover:scale-50" />
          <Icon name="arrow-up-right" size={15} class="absolute inset-0 opacity-0 scale-50 transition-all duration-200 group-hover:opacity-100 group-hover:scale-100" />
        </span>
      </a>
      <button id="menu-toggle" class="md:hidden btn btn-ghost !p-2.5" aria-label="Menu" aria-expanded="false">
        <Icon name="menu" size={20} />
      </button>
    </div>
  </div>

  <!-- mobile drawer -->
  <div id="mobile-nav" class="mobile-nav md:hidden">
    <nav class="container-x flex flex-col py-3" aria-label="Mobile">
      {
        NAV.map((item) =>
          item.children ? (
            <div class="mnav-group">
              <span class="mnav-parent">{item.label}</span>
              {item.children.map((c) =>
                c.soon ? (
                  <span class="mnav-link is-soon">
                    {c.label}
                    <span class="dd-soon">yakında</span>
                  </span>
                ) : (
                  <a href={c.href} class:list={["mnav-link", isActive(c.href) && "text-grad"]} data-track="nav_click" data-track-props={JSON.stringify({ location: "header", nav_label: c.label, href: c.href })}>
                    {c.label}
                    <Icon name="chevron-right" size={16} />
                  </a>
                ),
              )}
            </div>
          ) : (
            <a href={item.href} class:list={["mnav-link", isActive(item.href) && "text-grad"]} data-track="nav_click" data-track-props={JSON.stringify({ location: "header", nav_label: item.label, href: item.href })}>
              {item.label}
              <Icon name="chevron-right" size={16} />
            </a>
          ),
        )
      }
      <button type="button" data-search-open class="btn btn-ghost mt-3 justify-center !rounded-xl"><Icon name="search" size={16} /> Ara</button>
      <a href={JOIN_FORM} target="_blank" rel="noopener noreferrer" class="btn btn-ghost mt-2 justify-center !rounded-xl" data-track="join_click" data-track-props={JSON.stringify({ location: "mobile-nav" })}><Icon name="user-check" size={16} /> Aramıza katıl</a>
      <button type="button" data-contact="newsletter" class="btn btn-ghost mt-2 justify-center !rounded-xl"><Icon name="bell" size={16} /> Bültene abone ol</button>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid transparent;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }
  /* soft top scrim so the transparent navbar never reveals hero photos behind it */
  .site-header::before {
    content: "";
    position: absolute;
    inset-inline: 0;
    top: 0;
    height: 8rem;
    background: linear-gradient(to bottom, var(--color-ink-950) 40%, transparent);
    pointer-events: none;
    z-index: -1;
    transition: opacity 0.3s var(--ease-out-soft);
  }
  .site-header.scrolled::before {
    opacity: 0;
  }
  .site-header.scrolled {
    background: var(--color-ink-950);
    border-bottom-color: var(--color-line);
  }

  /* Logo: on scroll the "MultiGroup" wordmark collapses away (Anthropic-style)
     and the flower mark spins a full 360°. The brand keeps a fixed 135px
     footprint so the collapse never shifts the nav links. */
  .brand {
    position: relative;
    /* Constant footprint across all variants so the nav never shifts between
       MultiGroup / Store / Academy. The mark + wordmark are left-aligned inside
       it; --brand-w only sizes the internal wordmark slot (and the image word). */
    width: var(--brand-box, 196px);
    height: var(--brand-h, 28px);
    flex: none;
  }
  .brand-mark {
    position: absolute;
    left: 0;
    top: 0;
    height: var(--brand-h, 28px);
    display: flex;
    align-items: center;
    transition: transform 1.1s var(--ease-out-soft);
  }
  .brand-mark img {
    display: block;
    height: var(--brand-h, 28px);
    width: auto;
  }
  .brand-word {
    position: absolute;
    left: var(--brand-word-left, 28px); /* sits right after the mark */
    top: 0;
    width: calc(var(--brand-w, 135px) - var(--brand-word-left, 28px));
    height: var(--brand-h, 28px);
    overflow: hidden;
    transition: width 0.9s var(--ease-out-soft), opacity 0.7s var(--ease-out-soft);
  }
  .brand-word img {
    display: block;
    height: var(--brand-h, 28px);
    width: var(--brand-w, 135px);
    max-width: none;
    margin-left: calc(-1 * var(--brand-word-left, 28px)); /* hide the mark; show only the wordmark */
  }
  /* text wordmark (store variant) — Geist (the logo typeface): "Multi" 700 +
     "Store" 300, mirroring the dmg-logo lockup. Tune --store-word-size to match. */
  .brand-word-text {
    display: block;
    white-space: nowrap;
    font-family: "Hanken Grotesk", var(--font-display), system-ui, sans-serif;
    font-weight: 300;
    font-size: var(--store-word-size, 1.39rem);
    line-height: var(--brand-h, 28px);
    letter-spacing: -0.01em;
    color: #fff;
  }
  .brand-word-text b {
    font-weight: 700;
  }
  .site-header.scrolled .brand-mark {
    transform: rotate(var(--brand-spin, 180deg));
  }
  .site-header.scrolled .brand-word {
    width: 0;
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .brand-mark,
    .brand-word {
      transition: none;
    }
    .site-header.scrolled .brand-mark {
      transform: none;
    }
  }
  .nav-link {
    position: relative;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    font-size: 0.9rem;
    color: var(--color-ink-dim);
    transition: color 0.2s var(--ease-out-soft);
  }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0.9rem;
    right: 0.9rem;
    bottom: 0.26rem;
    height: 1.5px;
    border-radius: 2px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: center;
    opacity: 0;
    transition: transform 0.25s var(--ease-out-soft), opacity 0.2s;
  }
  .nav-link:hover {
    color: var(--color-ink-text);
  }
  .nav-link-active {
    color: var(--color-ink-text);
  }
  .nav-link:hover::after,
  .nav-link-active::after {
    transform: scaleX(1);
    opacity: 1;
  }

  /* partner dropdown */
  .nav-dd { position: relative; }
  .dd-caret { transform: rotate(90deg); opacity: 0.5; }
  .nav-dd-menu {
    position: absolute;
    top: 100%;
    left: 0;
    padding-top: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.2s var(--ease-out-soft), transform 0.2s var(--ease-out-soft), visibility 0.2s;
    z-index: 60;
  }
  .nav-dd:hover .nav-dd-menu,
  .nav-dd:focus-within .nav-dd-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .nav-dd-panel {
    min-width: 13rem;
    padding: 0.4rem;
    border-radius: 16px;
    border: 1px solid var(--color-line);
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(16px) saturate(140%);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .nav-dd-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.55rem 0.7rem;
    border-radius: 10px;
    font-size: 0.9rem;
    color: var(--color-ink-dim);
    transition: background-color 0.15s, color 0.15s;
  }
  a.nav-dd-link:hover,
  .nav-dd-link.is-current {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-ink-text);
  }
  .nav-dd-link.is-soon { color: var(--color-ink-faint); cursor: default; }
  .dd-soon {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.12rem 0.45rem;
    border-radius: 999px;
    border: 1px solid var(--color-line);
    color: var(--color-ink-faint);
  }

  .mobile-nav {
    overflow: hidden;
    max-height: 0;
    border-bottom: 1px solid transparent;
    background: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(14px);
    transition: max-height 0.35s var(--ease-out-soft), border-color 0.35s;
  }
  .mobile-nav.open {
    max-height: 40rem;
    border-bottom-color: var(--color-line);
  }
  .mnav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 0.25rem;
    border-bottom: 1px solid var(--color-line-soft);
    color: var(--color-ink-text);
    font-family: var(--font-display);
    font-size: 1.05rem;
  }
  .mnav-parent {
    display: block;
    padding: 0.9rem 0.25rem 0.35rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-faint);
  }
  .mnav-link.is-soon { color: var(--color-ink-faint); }
</style>

<script is:inline>
  (() => {
    const onScroll = () => {
      const h = document.getElementById("site-header");
      if (h) h.classList.toggle("scrolled", window.scrollY > 8);
    };
    const bind = () => {
      onScroll();
      const t = document.getElementById("menu-toggle");
      const d = document.getElementById("mobile-nav");
      if (t && d)
        t.onclick = () => {
          const open = d.classList.toggle("open");
          t.setAttribute("aria-expanded", String(open));
        };
    };
    if (!window.__dmgHeader) {
      window.__dmgHeader = true;
      window.addEventListener("scroll", onScroll, { passive: true });
      document.addEventListener("astro:page-load", bind);
    }
    bind();
  })();
</script>
