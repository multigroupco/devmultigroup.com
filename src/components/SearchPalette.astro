---
import Icon from "./Icon.astro";
---

<div id="search-palette" class="dmg-search" aria-hidden="true">
  <div class="dmg-search-backdrop" data-search-close></div>
  <div class="dmg-search-panel" role="dialog" aria-modal="true" aria-label="Site içi arama">
    <div class="dmg-search-head">
      <Icon name="search" size={18} />
      <input
        id="search-input"
        type="text"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        enterkeyhint="search"
        placeholder="Etkinlik, yazı, kayıt, ekip ara…"
        aria-label="Ara"
        aria-controls="search-results"
      />
      <button type="button" class="dmg-search-esc" data-search-close aria-label="Kapat">ESC</button>
    </div>
    <div id="search-results" class="dmg-search-results" role="listbox" aria-label="Arama sonuçları"></div>
    <div class="dmg-search-foot">
      <span><kbd>↑</kbd><kbd>↓</kbd> Gez</span>
      <span><kbd>↵</kbd> Aç</span>
      <span class="dmg-search-hint">Anlamsal arama · bge-m3</span>
    </div>
  </div>
</div>

<style is:global>
  .dmg-search { position: fixed; inset: 0; z-index: 120; display: none; }
  .dmg-search.open { display: block; }
  .dmg-search-backdrop {
    position: absolute; inset: 0;
    background: rgba(0, 0, 0, 0.62);
    backdrop-filter: blur(6px);
    opacity: 0; transition: opacity 0.35s ease;
  }
  .dmg-search.open .dmg-search-backdrop { opacity: 1; animation: dmg-search-fade 0.4s var(--ease-out-soft); }
  @keyframes dmg-search-fade { from { opacity: 0; } to { opacity: 1; } }
  .dmg-search-panel {
    position: absolute; left: 50%; top: 12vh;
    transform: translateX(-50%) translateY(-6px);
    width: min(92vw, 40rem); max-height: 70vh;
    display: flex; flex-direction: column;
    border: 1px solid var(--color-line);
    border-radius: 18px;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(20px) saturate(140%);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
    overflow: hidden; opacity: 0;
    transition: opacity 0.35s var(--ease-out-soft), transform 0.35s var(--ease-out-soft);
  }
  .dmg-search.open .dmg-search-panel {
    opacity: 1; transform: translateX(-50%) translateY(0);
    animation: dmg-search-pop 0.42s var(--ease-out-soft);
  }
  @keyframes dmg-search-pop {
    from { opacity: 0; transform: translateX(-50%) translateY(-14px) scale(0.97); }
    to { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
  }
  .dmg-search-head {
    display: flex; align-items: center; gap: 0.7rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--color-line-soft);
  }
  .dmg-search-head > svg { color: var(--color-ink-faint); flex: none; }
  #search-input {
    flex: 1; min-width: 0;
    background: transparent; border: 0; outline: 0;
    color: var(--color-ink-text);
    font-size: 1rem; font-family: var(--font-display);
  }
  #search-input::placeholder { color: var(--color-ink-faint); }
  .dmg-search-esc {
    flex: none; font-size: 0.62rem; letter-spacing: 0.04em;
    color: var(--color-ink-faint);
    border: 1px solid var(--color-line); border-radius: 6px;
    padding: 0.18rem 0.45rem; cursor: pointer; background: transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .dmg-search-esc:hover { color: var(--color-ink-text); border-color: var(--color-ink-faint); }
  .dmg-search-results { overflow-y: auto; padding: 0.4rem; flex: 1; }
  .sr-group {
    font-size: 0.64rem; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--color-ink-faint); padding: 0.75rem 0.6rem 0.3rem;
  }
  .sr-item {
    display: block; padding: 0.5rem 0.65rem; border-radius: 10px;
    text-decoration: none; color: var(--color-ink-text); cursor: pointer;
  }
  .sr-item .sr-title { display: block; font-size: 0.92rem; line-height: 1.3; }
  .sr-item .sr-snip {
    display: block; font-size: 0.76rem; color: var(--color-ink-dim);
    margin-top: 0.1rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .sr-item[aria-selected="true"] { background: rgba(255, 255, 255, 0.07); }
  .sr-msg {
    padding: 2.75rem 1rem; text-align: center;
    color: var(--color-ink-dim); font-size: 0.88rem;
  }
  .sr-msg-title {
    display: block; color: var(--color-ink-text);
    font-family: var(--font-display); font-size: 1rem;
  }
  .sr-msg-sub {
    display: block; color: var(--color-ink-faint);
    font-size: 0.8rem; margin-top: 0.6rem; line-height: 1.5;
  }
  .dmg-search-foot {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.55rem 1rem; border-top: 1px solid var(--color-line-soft);
    font-size: 0.7rem; color: var(--color-ink-faint);
  }
  .dmg-search-foot kbd {
    border: 1px solid var(--color-line); border-radius: 5px;
    padding: 0.05rem 0.32rem; margin-right: 0.15rem;
    font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.66rem;
  }
  .dmg-search-hint { margin-left: auto; font-family: var(--font-mono, ui-monospace, monospace); }
  @media (max-width: 640px) {
    .dmg-search-panel { top: 6vh; max-height: 82vh; }
    .dmg-search-hint { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .dmg-search-backdrop, .dmg-search-panel { transition: none; animation: none; }
  }
</style>

<script is:inline>
  (() => {
    const el = () => document.getElementById("search-palette");
    const input = () => document.getElementById("search-input");
    const box = () => document.getElementById("search-results");
    const isOpen = () => el()?.classList.contains("open");

    let controller = null;
    let debounce = null;
    let items = [];
    let active = -1;

    const esc = (s) =>
      String(s ?? "").replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c],
      );

    const EMPTY =
      '<div class="sr-msg"><span class="sr-msg-title">Ne arıyorsun?</span><span class="sr-msg-sub">Etkinlik, yazı, kayıt, bağlantı, ekip, topluluk…</span></div>';

    function open() {
      const e = el();
      if (!e) return;
      e.classList.add("open");
      e.setAttribute("aria-hidden", "false");
      document.getElementById("mobile-nav")?.classList.remove("open");
      document.documentElement.style.overflow = "hidden";
      const i = input();
      setTimeout(() => { i?.focus(); i?.select(); }, 40);
      if (i && i.value.trim().length >= 2) runSearch(i.value);
      else if (box()) { box().innerHTML = EMPTY; items = []; active = -1; }
    }

    function close() {
      const e = el();
      if (!e) return;
      e.classList.remove("open");
      e.setAttribute("aria-hidden", "true");
      document.documentElement.style.overflow = "";
      controller?.abort();
    }

    function highlight(next) {
      if (!items.length) { active = -1; return; }
      active = (next + items.length) % items.length;
      items.forEach((it, i) => it.setAttribute("aria-selected", i === active ? "true" : "false"));
      items[active]?.scrollIntoView({ block: "nearest" });
    }

    function render(results) {
      const b = box();
      if (!b) return;
      if (!results.length) {
        b.innerHTML = '<div class="sr-msg">Sonuç bulunamadı.</div>';
        items = []; active = -1; return;
      }
      // group by type, order groups by best score within each
      const groups = new Map();
      for (const r of results) {
        if (!groups.has(r.type)) groups.set(r.type, { label: r.label, rows: [], max: -Infinity });
        const g = groups.get(r.type);
        g.rows.push(r);
        g.max = Math.max(g.max, r.score || 0);
      }
      const ordered = [...groups.values()].sort((a, b2) => b2.max - a.max);
      let html = "";
      for (const g of ordered) {
        html += `<div class="sr-group">${esc(g.label)}</div>`;
        for (const r of g.rows) {
          html +=
            `<a class="sr-item" href="${esc(r.url)}" data-sr role="option">` +
            `<span class="sr-title">${esc(r.title)}</span>` +
            (r.snippet ? `<span class="sr-snip">${esc(r.snippet)}</span>` : "") +
            `</a>`;
        }
      }
      b.innerHTML = html;
      items = [...b.querySelectorAll("[data-sr]")];
      highlight(0);
    }

    async function runSearch(q) {
      const b = box();
      if (!b) return;
      q = q.trim();
      if (q.length < 2) { b.innerHTML = EMPTY; items = []; active = -1; return; }
      controller?.abort();
      controller = new AbortController();
      b.setAttribute("aria-busy", "true");
      try {
        const r = await fetch(`/api/search?q=${encodeURIComponent(q)}`, { signal: controller.signal });
        const j = await r.json();
        if (input()?.value.trim() === q) render(j.results || []);
      } catch (err) {
        if (err.name !== "AbortError") {
          b.innerHTML = '<div class="sr-msg">Arama şu an kullanılamıyor.</div>';
          items = []; active = -1;
        }
      } finally {
        b.removeAttribute("aria-busy");
      }
    }

    if (!window.__dmgSearch) {
      window.__dmgSearch = true;

      // Open/close triggers + result clicks (delegated, survives view transitions).
      document.addEventListener("click", (e) => {
        if (e.target.closest("[data-search-open]")) { e.preventDefault(); open(); return; }
        if (e.target.closest("[data-search-close]")) { e.preventDefault(); close(); return; }
        // result click: close (clears scroll lock) then let ClientRouter navigate
        if (e.target.closest("[data-sr]")) close();
      });

      document.addEventListener("input", (e) => {
        if (e.target.id !== "search-input") return;
        clearTimeout(debounce);
        const q = e.target.value;
        debounce = setTimeout(() => runSearch(q), 160);
      });

      document.addEventListener("keydown", (e) => {
        // ⌘K / Ctrl-K toggles from anywhere
        if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
          e.preventDefault();
          isOpen() ? close() : open();
          return;
        }
        // "/" opens when not already typing in a field
        if (e.key === "/" && !isOpen()) {
          const t = e.target;
          const typing = t && (t.tagName === "INPUT" || t.tagName === "TEXTAREA" || t.isContentEditable);
          if (!typing) { e.preventDefault(); open(); return; }
        }
        if (!isOpen()) return;
        if (e.key === "Escape") { e.preventDefault(); close(); }
        else if (e.key === "ArrowDown") { e.preventDefault(); highlight(active + 1); }
        else if (e.key === "ArrowUp") { e.preventDefault(); highlight(active - 1); }
        else if (e.key === "Enter") {
          if (active >= 0 && items[active]) { e.preventDefault(); items[active].click(); }
        }
      });

      document.addEventListener("mouseover", (e) => {
        const it = e.target.closest("[data-sr]");
        if (it && items.length) {
          const i = items.indexOf(it);
          if (i >= 0 && i !== active) highlight(i);
        }
      });

      // Always reset scroll-lock + close after any client-side navigation.
      document.addEventListener("astro:page-load", () => {
        document.documentElement.style.overflow = "";
        el()?.classList.remove("open");
        el()?.setAttribute("aria-hidden", "true");
      });
    }
  })();
</script>
