---
import Icon from "./Icon.astro";
import AsciiFlower from "./AsciiFlower.astro";
import { BRAND, FOOTER_NAV, SOCIALS, SUBBRANDS } from "@/lib/site";

const year = new Date().getFullYear();
const mg = SOCIALS.multigroup;
const social = [
  { icon: "instagram", href: mg.instagram, label: "Instagram" },
  { icon: "twitter", href: mg.twitter, label: "X / Twitter" },
  { icon: "linkedin", href: mg.linkedin, label: "LinkedIn" },
  { icon: "youtube", href: mg.youtube, label: "YouTube" },
  { icon: "github", href: mg.github, label: "GitHub" },
];
---

<footer class="relative mt-24 border-t border-line">
  <div class="container-x py-12 md:py-14">
    <div class="grid gap-12 lg:gap-10 lg:grid-cols-[300px_1fr_1.3fr]">
      <!-- LEFT — rotating 3D ASCII flower -->
      <div class="flex justify-center lg:justify-start">
        <AsciiFlower />
      </div>

      <!-- MIDDLE — MultiGroup links + socials -->
      <div>
        <a href="/" class="fw text-2xl inline-block leading-none"><b>Multi</b>Group</a>
        <p class="text-ink-dim text-sm leading-relaxed mt-3 max-w-xs">
          Geliştiricilerin birlikte büyüdüğü gönüllü topluluk.
        </p>

        <nav class="grid grid-cols-2 gap-x-8 gap-y-2.5 mt-6" aria-label="Footer">
          {
            FOOTER_NAV.map((n) => (
              <a
                href={n.href}
                data-track="nav_click"
                data-track-props={JSON.stringify({ location: "footer", nav_label: n.label, href: n.href })}
                class="text-ink-dim hover:text-ink-text text-sm transition-colors"
              >
                {n.label}
              </a>
            ))
          }
        </nav>

        <div class="flex items-center gap-2 mt-7">
          {
            social.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                data-track="social_click"
                data-track-props={JSON.stringify({ platform: s.icon, location: "footer" })}
                class="grid place-items-center w-9 h-9 text-ink-dim hover:text-ink-text transition-colors"
              >
                <Icon name={s.icon} size={16} />
              </a>
            ))
          }
          <button
            type="button"
            data-contact="support"
            aria-label="Bize ulaş"
            title="Bize ulaş"
            class="grid place-items-center w-9 h-9 text-ink-dim hover:text-ink-text transition-colors"
          >
            <Icon name="mail" size={16} />
          </button>
        </div>
      </div>

      <!-- RIGHT — sub-brands -->
      <div class="lg:border-l lg:border-line-soft lg:pl-10">
        <div class="space-y-px">
          {
            SUBBRANDS.map((sb) => (
              <div class="flex items-start justify-between gap-4 border-t border-line-soft py-3.5 first:border-t-0 lg:first:pt-0">
                <div class="min-w-0">
                  {sb.href ? (
                    <a
                      href={sb.href}
                      data-track="nav_click"
                      data-track-props={JSON.stringify({ location: "footer-subbrand", nav_label: `${sb.strong}${sb.tail}`, href: sb.href })}
                      class="fw text-base leading-none hover:text-grad transition-colors"
                    ><b>{sb.strong}</b>{sb.tail}</a>
                  ) : (
                    <span class="fw text-base leading-none"><b>{sb.strong}</b>{sb.tail}</span>
                  )}
                  <p class="text-ink-faint text-xs leading-relaxed mt-1.5 max-w-xs">{sb.desc}</p>
                </div>
                <div class="flex items-center gap-1.5 shrink-0 pt-0.5">
                  {sb.socials.map((s) => (
                    <a
                      href={s.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={s.label}
                      data-track="social_click"
                      data-track-props={JSON.stringify({ platform: s.icon, location: "footer-subbrand" })}
                      class="grid place-items-center w-8 h-8 text-ink-dim hover:text-ink-text transition-colors"
                    >
                      <Icon name={s.icon} size={15} />
                    </a>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-line-soft flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-ink-faint">
      <p>© 2020–{year} {BRAND.name}.</p>
      <p class="font-mono">{BRAND.tagline.toLowerCase()}</p>
    </div>
  </div>

  <style>
    /* footer wordmarks — same Hanken "Multi" bold + light tail as the navbar */
    .fw {
      font-family: "Hanken Grotesk", var(--font-display), system-ui, sans-serif;
      font-weight: 300;
      letter-spacing: -0.01em;
      color: var(--color-ink-text);
    }
    .fw b {
      font-weight: 700;
    }
  </style>
</footer>
