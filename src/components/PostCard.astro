---
import { formatDate } from "@/lib/format";
import { imageSrc, categoryLabel } from "@/lib/ui";
import type { PostRow } from "@/lib/types";

interface Props {
  post: PostRow;
  featured?: boolean;
  /** Analytics context: which page/section the card is rendered on. */
  page?: string;
}
const { post, featured = false, page } = Astro.props;
const trackProps = JSON.stringify({
  post_slug: post.slug,
  post_title: post.title,
  post_category: post.category,
  page,
});
// Real cover if set, otherwise a dynamically generated monochrome banner
// (which already prints the category — so no chip overlay here).
const cover = imageSrc(post.cover_image) || `/blog/banner/${post.slug}.svg`;
const href = `/blog/${post.slug}`;
---

<article class="card card-hover relative overflow-hidden flex flex-col h-full">
  <div
    class:list={[
      "relative overflow-hidden skeleton",
      featured ? "aspect-[16/10] lg:aspect-auto lg:flex-1 lg:min-h-[4rem]" : "aspect-[16/9]",
    ]}
  >
    <img
      src={cover}
      alt=""
      loading="lazy"
      decoding="async"
      onload="this.parentElement.classList.remove('skeleton')"
      class="absolute inset-0 w-full h-full object-cover"
    />
  </div>
  <div class:list={["flex flex-col", featured ? "p-6 md:p-7" : "p-5 flex-1"]}>
    {featured && post.category && (
      <p class="text-[0.65rem] uppercase tracking-wide text-ink-faint font-mono mb-2">{categoryLabel(post.category)}</p>
    )}
    <h3 class:list={["font-display font-semibold leading-snug", featured ? "text-xl md:text-2xl" : "text-lg"]}>
      <a href={href} class="after:absolute after:inset-0" data-track="blog_post_click" data-track-props={trackProps}>{post.title}</a>
    </h3>
    {!featured && post.excerpt && <p class="text-ink-dim text-sm mt-2 line-clamp-3">{post.excerpt}</p>}
    <div class:list={["flex items-center gap-2 text-xs text-ink-faint", featured ? "mt-5" : "mt-4"]}>
      <span>{post.author}</span>
      <span class="opacity-40">•</span>
      <span>{formatDate(post.published_at ?? post.created_at)}</span>
      <span class="opacity-40">•</span>
      <span>{post.reading_minutes} dk okuma</span>
    </div>
  </div>
</article>
