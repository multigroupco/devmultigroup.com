---
// Scattered binary (0/1) texture for behind hero text — dim monochrome code
// rain on black, radial-masked so it fades at the edges. Decorative only.
interface Props {
  rows?: number;
  cols?: number;
  density?: number; // 0..1 share of cells that are a digit (rest blank)
}
const { rows = 26, cols = 64, density = 0.4 } = Astro.props;
let text = "";
for (let r = 0; r < rows; r++) {
  let s = "";
  for (let c = 0; c < cols; c++) {
    s += Math.random() < density ? (Math.random() < 0.5 ? "0" : "1") : " ";
  }
  text += s + (r < rows - 1 ? "\n" : "");
}
---

<pre class="binary-bg" aria-hidden="true">{text}</pre>

<style>
  .binary-bg {
    position: absolute;
    inset: 0;
    margin: 0;
    overflow: hidden;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.8rem;
    line-height: 1.4;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.1);
    white-space: pre;
    pointer-events: none;
    user-select: none;
    -webkit-mask-image: radial-gradient(135% 125% at 78% 45%, #000 32%, transparent 92%);
    mask-image: radial-gradient(135% 125% at 78% 45%, #000 32%, transparent 92%);
  }
</style>
