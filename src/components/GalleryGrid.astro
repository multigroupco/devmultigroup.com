---
import { imageSrc } from "@/lib/ui";
import type { GalleryRow } from "@/lib/types";

interface Props {
  items: GalleryRow[];
}
const { items } = Astro.props;
---

<div class="gallery-grid">
  {
    items.map((it) => {
      const src = imageSrc(it.image_url || it.image_key);
      const cap = it.title || it.caption;
      return (
        <figure class="gallery-item card overflow-hidden relative group skeleton" data-full={src}>
          <img src={src} alt={cap || "Community photo"} loading="lazy" decoding="async" onload="this.parentElement.classList.remove('skeleton')" class="w-full block" />
          {cap && <figcaption class="gallery-cap">{cap}</figcaption>}
        </figure>
      );
    })
  }
</div>

<div id="lightbox" class="lightbox" hidden>
  <button id="lightbox-close" class="lightbox-close" aria-label="Close">×</button>
  <img id="lightbox-img" alt="" />
</div>

<style>
  .gallery-grid {
    columns: 1;
    column-gap: 1rem;
  }
  @media (min-width: 540px) {
    .gallery-grid { columns: 2; }
  }
  @media (min-width: 900px) {
    .gallery-grid { columns: 3; }
  }
  .gallery-item {
    break-inside: avoid;
    margin-bottom: 1rem;
    cursor: zoom-in;
  }
  .gallery-item img {
    transition: transform 0.5s var(--ease-out-soft);
  }
  .gallery-item:hover img {
    transform: scale(1.04);
  }
  .gallery-cap {
    position: absolute;
    inset: auto 0 0 0;
    padding: 1.4rem 0.9rem 0.7rem;
    font-size: 0.8rem;
    color: #fff;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .gallery-item:hover .gallery-cap {
    opacity: 1;
  }
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    padding: 1.5rem;
    background: rgba(5, 4, 8, 0.92);
    backdrop-filter: blur(8px);
  }
  .lightbox[hidden] { display: none; }
  .lightbox img {
    max-width: min(92vw, 1100px);
    max-height: 88vh;
    border-radius: 14px;
    border: 1px solid var(--color-line);
  }
  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    font-size: 2rem;
    line-height: 1;
    color: var(--color-ink-dim);
  }
  .lightbox-close:hover { color: #fff; }
</style>

<script is:inline>
  (() => {
    const bind = () => {
      const box = document.getElementById("lightbox");
      const img = document.getElementById("lightbox-img");
      if (!box || !img) return;
      const open = (src) => {
        img.setAttribute("src", src);
        box.hidden = false;
      };
      window.__dmgLbClose = () => {
        box.hidden = true;
        img.setAttribute("src", "");
      };
      document.querySelectorAll(".gallery-item").forEach((el) => {
        el.onclick = () => {
          const src = el.getAttribute("data-full");
          if (src) open(src);
        };
      });
      box.onclick = (e) => {
        if (e.target === box || e.target.id === "lightbox-close") window.__dmgLbClose();
      };
    };
    if (!window.__dmgGallery) {
      window.__dmgGallery = true;
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && window.__dmgLbClose) window.__dmgLbClose();
      });
      document.addEventListener("astro:page-load", bind);
    }
    bind();
  })();
</script>
